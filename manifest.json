{
  "manifest_version": 3,
  "name": "NBA Anti Spoiler",
  "version": "3.0.0",
  "description": "Block NBA playoff spoilers on YouTube.",
  "permissions": ["storage", "activeTab", "alarms"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://site.api.espn.com/*",
    "https://a.espncdn.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
      "type": "module"


  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}